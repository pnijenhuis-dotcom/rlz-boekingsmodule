# Kopieer naar .env en pas aan indien nodig. Standaardwaarden verwachten lokale PostgreSQL 16
# (Homebrew, `brew install postgresql@16`) op poort 5433 — zie README.md voor waarom.

DATABASE_URL=postgresql+psycopg://postgres@localhost:5433/boekhouding
APP_DATABASE_URL=postgresql+psycopg://boekhouding_app:devpassword@localhost:5433/boekhouding
TEST_DATABASE_URL=postgresql+psycopg://postgres@localhost:5433/boekhouding_test
TEST_APP_DATABASE_URL=postgresql+psycopg://boekhouding_app:devpassword@localhost:5433/boekhouding_test

# Alleen lokale dev: wachtwoord van de least-privilege app-rol die migratie 0001 aanmaakt.
# In Cloud Run komt dit uit Secret Manager, nooit hier.
APP_DB_PASSWORD=devpassword

# Alleen lokale dev: JWT-signing-secret (migratie 0002-auth) en de masterkey (base64, 32 bytes)
# voor envelope-encryptie van totp_secret. Leeg laten = dev-only fallback (zie
# app/security/tokens.py::_resolve_jwt_secret, app/security/envelope.py::_resolve_master_key) —
# buiten dev/local faalt de app hard zonder deze twee expliciet gezet (Cloud Run: Secret Manager).
# JWT_SECRET=
# TOTP_MASTER_KEY=
